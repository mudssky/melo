{
  "name": "melo",
  "version": "1.0.0",
  "private": true,
  "bin": {
    "melo": "./bin/melo-dev.cjs"
  },
  "scripts": {
    "lint-staged": "lint-staged",
    "format:rs": "cargo fmt --all",
    "format:ts": "biome format --write .",
    "format:rs:check": "cargo fmt --all --check",
    "check:ts": "biome check --write .",
    "lint:rs": "cargo clippy --no-deps -- -D warnings",
    "lint:rs:fix": "cargo clippy --no-deps --fix --allow-dirty -- -D warnings",
    "lint:rs:ci": "cargo clippy --all-targets --no-deps -j 8 -- -D warnings",
    "lint:rs:full": "cargo clippy -j 8 --all-targets --all-features -- -D warnings",
    "lint:rs:rtk": "rtk cargo clippy --no-deps -- -D warnings",
    "typecheck": "tsc --noEmit",
    "precommit:rs": "pnpm format:rs:check && pnpm lint:rs",
    "prepare": "husky",
    "test:rs": "cargo test -q",
    "test:rs:lib": "cargo test --lib -q",
    "test:rs:norun": "cargo test --no-run",
    "test:rs:rtk": "rtk cargo test -q",
    "test:dev-cli": "vitest run tests/dev-cli",
    "test:ts": "vitest run",
    "install:dev": "cargo install --path . --force",
    "install:dev:safe": "node ./scripts/dev-cli/install-dev.cjs",
    "link:dev": "node ./scripts/dev-cli/link-dev.cjs",
    "unlink:dev": "pnpm uninstall --global melo",
    "setup:dev": "pnpm install:dev:safe && pnpm link:dev",
    "watch:install": "watchexec --postpone --watch src --watch bin --watch Cargo.toml --watch Cargo.lock --watch config.dev.toml --watch package.json --ignore target --ignore node_modules --ignore .git --ignore local --shell=none -- pnpm install:dev:safe",
    "qa:rs": "pnpm format:rs && pnpm lint:rs:rtk && pnpm test:rs:rtk",
    "qa:ts": "pnpm check:ts && pnpm typecheck && pnpm test:ts",
    "qa": "concurrently --prefix none --group --kill-others-on-fail \"pnpm qa:ts\" \"pnpm qa:rs\""
  },
  "packageManager": "pnpm@10.26.1",
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@types/node": "^25.6.0",
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "rumdl": "^0.1.67",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
